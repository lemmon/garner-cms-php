{% extends "base.twig" %}

{% block content %}
    <article class="about">
        <h1>{{ page.title }}</h1>
        {% set logo = page.file('garner.svg') %}
        {% if logo %}
            <img src="{{ logo.url }}" alt="{{ logo.get('alt') }}" width="320" height="120">
        {% endif %}
        {{ content.main|markdown }}
        <p><a href="/">&larr; Home</a></p>
    </article>
{% endblock %}
