<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>{{ page.title }} | {{ site.title }}</title>
  </head>
  <body>
    <main>
      <header>
        <p><a href="/">{{ site.title }}</a></p>
        <nav aria-label="Pages">
          <h2>Listed Pages</h2>
          <ul>
            {% for item in pages.listed() %}
              <li><a href="{{ item.url }}">{{ item.title }}</a></li>
            {% else %}
              <li>No listed pages</li>
            {% endfor %}
          </ul>

          <h2>Unlisted Pages</h2>
          <ul>
            {% for item in pages.unlisted() %}
              <li><a href="{{ item.url }}">{{ item.title }}</a></li>
            {% else %}
              <li>No unlisted pages</li>
            {% endfor %}
          </ul>
        </nav>
      </header>

      <article>
        <h1>{{ page.title }}</h1>
        {% set text = page.value('text') %}
        {% if text %}
          {{ text|markdown }}
        {% endif %}
      </article>
    </main>
  </body>
</html>
