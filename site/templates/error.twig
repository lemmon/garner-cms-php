<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    {% set error_title = page is defined ? page.title : (error.title ?? 'Application Error') %}
    <title>{{ error_title }} | {{ site.title }}</title>
  </head>
  <body>
    <main>
      <article>
        <h1>{{ error_title }}</h1>
        {% set text = page is defined ? page.value('text') : null %}
        {% if text %}
          {{ text|markdown }}
        {% elseif error.kind == 'not_found' %}
          <p>No page matched <code>{{ error.path }}</code>.</p>
        {% else %}
          <p>The request could not be completed.</p>
        {% endif %}
        <p><a href="/">Back to home</a></p>
      </article>
    </main>
  </body>
</html>
