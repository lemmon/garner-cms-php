<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>{{ page.title }} | {{ site.title }}</title>
  </head>
  <body>
    <main>
      <article>
        <h1>{{ page.title }}</h1>
        {% set text = page.value('text') %}
        {% if text %}
          {{ text|markdown }}
        {% else %}
          <p>No page matched <code>{{ path }}</code>.</p>
        {% endif %}
        <p><a href="/">Back to home</a></p>
      </article>
    </main>
  </body>
</html>
