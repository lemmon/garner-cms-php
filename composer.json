{
    "name": "lemmon/garner",
    "description": "Agent-first, flat-file PHP CMS with filesystem routing and Twig rendering",
    "license": "proprietary",
    "type": "library",
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "illuminate/collections": "^13",
        "league/commonmark": "^2",
        "lemmon/validator": "^0.15",
        "symfony/console": "^8",
        "symfony/dotenv": "^8",
        "symfony/error-handler": "^8",
        "symfony/filesystem": "^8",
        "symfony/http-foundation": "^8.1",
        "symfony/uid": "^8",
        "symfony/var-dumper": "^8",
        "symfony/yaml": "^8",
        "twig/twig": "^3",
        "visus/cuid2": "^6"
    },
    "require-dev": {
        "carthage-software/mago": "^1",
        "ergebnis/composer-normalize": "^2",
        "phpstan/phpstan": "^2",
        "phpunit/phpunit": "^13"
    },
    "autoload": {
        "psr-4": {
            "Garner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Garner\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/garner"
    ],
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        },
        "sort-packages": true
    },
    "scripts": {
        "analyze": "vendor/bin/phpstan analyse --memory-limit=1G",
        "check": [
            "@platform-check",
            "vendor/bin/mago format --check",
            "@analyze",
            "@lint",
            "@test"
        ],
        "format": "vendor/bin/mago format",
        "lint": "vendor/bin/mago lint",
        "platform-check": "composer check-platform-reqs",
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@php -S localhost:8040 -t public boot/server.php"
        ],
        "test": "phpunit"
    }
}
